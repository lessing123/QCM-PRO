# ================================================================
# QCM ESGIS — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ================================================================

# ── MySQL ────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=changeme-root-password
MYSQL_DATABASE=qcm_db
MYSQL_USER=qcm_user
MYSQL_PASSWORD=changeme-db-password

# ── JWT (obligatoire en production — générer avec : openssl rand -base64 32)
JWT_SECRET=changeme-jwt-secret-minimum-32-caracteres
JWT_REFRESH_SECRET=changeme-refresh-secret-minimum-32-chars
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ── Backend ──────────────────────────────────────────────────────
DATABASE_URL="mysql://qcm_user:changeme-db-password@localhost:3306/qcm_db"
PORT=3001

# ── Seeding (true = données de test au 1er démarrage seulement) ──
SEED_DB=false
