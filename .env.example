# ================================================================
# QCM ESGIS — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ================================================================

# ── MySQL (Docker) ──────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=rootsecret123
MYSQL_DATABASE=qcm_db
MYSQL_USER=qcm_user
MYSQL_PASSWORD=qcm_secret123

# ── JWT ─────────────────────────────────────────────────────────
# Générer des clés sécurisées : openssl rand -base64 32
JWT_SECRET=changeme-jwt-secret-minimum-32-caracteres
JWT_REFRESH_SECRET=changeme-refresh-secret-minimum-32-chars
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ── Backend (développement local sans Docker) ────────────────────
DATABASE_URL="mysql://qcm_user:qcm_secret123@localhost:3306/qcm_db"
PORT=3001

# ── Seeding ─────────────────────────────────────────────────────
# true = injecter les données de test au 1er démarrage Docker
SEED_DB=true

# ── Frontend (développement local uniquement) ────────────────────
VITE_API_URL=http://localhost:3001/api
