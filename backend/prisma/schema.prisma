generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  STUDENT
}

enum QuestionType {
  SINGLE
  MULTIPLE
  TRUE_FALSE
}

enum AttemptStatus {
  EN_COURS
  TERMINE
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique @db.VarChar(191)
  password  String
  nom       String    @db.VarChar(100)
  prenom    String    @db.VarChar(100)
  role                 Role      @default(STUDENT)
  password_temp        String?   @db.VarChar(255)
  must_change_password Boolean   @default(false)
  is_active            Boolean   @default(true)
  session_token        String?   @db.VarChar(36)
  is_online            Boolean   @default(false)
  last_seen DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  examsCreated  Exam[]         @relation("CreatedBy")
  attempts      Attempt[]
  groups        Group[]        @relation("UserGroups")
  notifications Notification[]
}

model Group {
  id          String   @id @default(uuid())
  nom         String   @unique @db.VarChar(191)
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users User[] @relation("UserGroups")
  exams Exam[] @relation("GroupExams")
}

model Exam {
  id                String    @id @default(uuid())
  titre             String    @db.VarChar(255)
  description       String?   @db.Text
  duree_minutes     Int       @default(60)
  date_debut        DateTime?
  date_fin          DateTime?
  tentatives_max    Int       @default(1)
  melange_questions Boolean   @default(false)
  melange_reponses  Boolean   @default(false)
  resultats_publics Boolean   @default(false)
  notif_sent        Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  createdBy   User       @relation("CreatedBy", fields: [createdById], references: [id])
  createdById String
  questions   Question[]
  attempts    Attempt[]
  groups      Group[]    @relation("GroupExams")

  @@index([createdById])
}

model Question {
  id        String       @id @default(uuid())
  examId    String
  enonce    String       @db.Text
  type      QuestionType @default(SINGLE)
  points    Int          @default(1)
  ordre     Int          @default(0)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  exam           Exam            @relation(fields: [examId], references: [id], onDelete: Cascade)
  answers        Answer[]
  studentAnswers StudentAnswer[]

  @@index([examId])
}

model Answer {
  id           String  @id @default(uuid())
  questionId   String
  texte        String  @db.Text
  image_url    String? @db.VarChar(500)
  est_correcte Boolean @default(false)
  ordre        Int     @default(0)

  question       Question        @relation(fields: [questionId], references: [id], onDelete: Cascade)
  studentAnswers StudentAnswer[]

  @@index([questionId])
}

model Attempt {
  id         String        @id @default(uuid())
  userId     String
  examId     String
  score      Float?
  date_debut DateTime      @default(now())
  date_fin   DateTime?
  statut     AttemptStatus @default(EN_COURS)
  bloque     Boolean       @default(false)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  user           User            @relation(fields: [userId], references: [id])
  exam           Exam            @relation(fields: [examId], references: [id])
  studentAnswers StudentAnswer[]

  @@index([userId])
  @@index([examId])
}

model StudentAnswer {
  id           String   @id @default(uuid())
  attemptId    String
  questionId   String
  answerId     String?
  est_correcte Boolean?
  createdAt    DateTime @default(now())

  attempt  Attempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id])
  answer   Answer?  @relation(fields: [answerId], references: [id])

  @@index([attemptId])
  @@index([questionId])
}

model Notification {
  id        String   @id @default(uuid())
  type      String   @db.VarChar(50)
  message   String   @db.Text
  userId    String
  examId    String?
  lu        Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
